# Anthropic — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google OAuth — see docs/setup/google-oauth.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Optional: override default ./data/app.db location
# VIP_DB_PATH=/abs/path/to/app.db
