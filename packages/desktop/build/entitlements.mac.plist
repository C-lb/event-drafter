<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron/V8 JIT under the hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- We fork child processes (next/worker) with ELECTRON_RUN_AS_NODE and set
       PLAYWRIGHT_BROWSERS_PATH; the bundled Chromium also reads dyld env vars. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- REQUIRED here: we load a native addon (better_sqlite3.node) and ship a
       Chromium that is signed by Google (a DIFFERENT Team ID), so the hardened
       runtime's library validation would otherwise refuse to load them. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- App runs a localhost HTTP server (Next on 127.0.0.1:41000) and makes
       outbound calls (Anthropic, Google, WhatsApp web). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
