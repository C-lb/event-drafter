    "test": "vitest run",
    "wa-smoke": "tsx src/wa/smoke.ts"
  },
  "dependencies": {
    "@event-drafter/core": "*",
    "@anthropic-ai/sdk": "^0.35.0",
    "drizzle-orm": "^0.36.0",
    "googleapis": "^144.0.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.0",
    "node-cron": "^3.0.3",
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
