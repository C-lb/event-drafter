{
  "name": "@event-drafter/worker",
  "version": "0.0.10",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./google/oauth": "./dist/google/oauth.js",
    "./google/sheets": "./dist/google/sheets.js",
    "./google/gmail": "./dist/google/gmail.js",
    "./wa/driver": "./dist/wa/driver.js",
    "./scheduler": "./dist/scheduler.js",
    "./rate-limit": "./dist/rate-limit.js"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
