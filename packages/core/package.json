{
  "name": "@event-drafter/core",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./db": "./dist/db.js",
    "./types": "./dist/types.js",
    "./migrate": "./dist/migrate.js",
    "./settings": "./dist/settings.js",
    "./edm-extract": "./dist/edm-extract.js",
    "./edm-templates": "./dist/edm-templates.js",
    "./message-templates": "./dist/message-templates.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "migrate": "tsx src/migrate.ts",
    "drizzle:generate": "node --import tsx/esm ../../node_modules/.bin/drizzle-kit generate"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
